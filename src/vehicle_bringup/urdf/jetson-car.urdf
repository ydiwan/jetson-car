<?xml version="1.0"?>
<robot name="jetson-car">

  <material name="blue"><color rgba="0 0 0.8 1"/></material>
  <material name="black"><color rgba="0 0 0 1"/></material>

  <link name="base_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <link name="chassis">
    <visual>
      <origin xyz="0.074 0 0.034" rpy="0 0 0"/>
      <geometry><box size="0.20 0.10 0.05"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0.074 0 0.034" rpy="0 0 0"/>
      <geometry><box size="0.20 0.10 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.074 0 0.034" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.004"/>
    </inertial>
  </link>
  <joint name="base_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
  </joint>

  <link name="rear_left_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="rl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="0 0.0665 0.034" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="rear_right_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="rr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="0 -0.0665 0.034" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="fl_steering_hinge">
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="fl_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fl_steering_hinge"/>
    <origin xyz="0.148 0.0665 0.034" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-0.52" upper="0.52" effort="10.0" velocity="5.0"/> 
  </joint>

  <link name="front_left_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="fl_wheel_joint" type="continuous">
    <parent link="fl_steering_hinge"/>
    <child link="front_left_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="fr_steering_hinge">
    <inertial><mass value="0.05"/><inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/></inertial>
  </link>
  <joint name="fr_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="fr_steering_hinge"/>
    <origin xyz="0.148 -0.0665 0.034" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-0.52" upper="0.52" effort="10.0" velocity="5.0"/> 
  </joint>

  <link name="front_right_wheel">
    <visual><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry><material name="black"/></visual>
    <collision><origin xyz="0 0 0" rpy="1.5708 0 0"/><geometry><cylinder radius="0.034" length="0.02"/></geometry></collision>
    <inertial><mass value="0.1"/><inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00003" iyz="0" izz="0.00006"/></inertial>
  </link>
  <joint name="fr_wheel_joint" type="continuous">
    <parent link="fr_steering_hinge"/>
    <child link="front_right_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.04 0.02"/></geometry> 
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.174 0 0.04" rpy="0 0 0"/>
  </joint>

  <gazebo reference="chassis">
    <sensor name="lane_camera" type="camera">
      <pose>0.25 0 0.1 0 0.2 0</pose> 
      <always_on>1</always_on>
      <update_rate>60</update_rate>
      <camera>
        <horizontal_fov>1.5</horizontal_fov>
        <image><width>1280</width><height>720</height></image>
        <clip><near>0.1</near><far>100</far></clip>
      </camera>
      <topic>/camera/lane/raw_video</topic>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-ackermann-steering-system" name="gz::sim::systems::AckermannSteering">
      <left_joint>rl_wheel_joint</left_joint>
      <right_joint>rr_wheel_joint</right_joint>
      <left_steering_joint>fl_steering_joint</left_steering_joint>
      <right_steering_joint>fr_steering_joint</right_steering_joint>
      <wheelbase>0.148</wheelbase>
      <wheel_separation>0.133</wheel_separation>
      <wheel_radius>0.034</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
    </plugin>
  </gazebo>
</robot>